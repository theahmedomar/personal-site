---
// D6 — one workload, two poll strategies. Synchronized timers stack every tab onto
// the same tick and spike past capacity; jittered timers spread the identical total
// load flat and stay under the line. Shaded areas are drawn ~equal on purpose.
const base = 188;
const cap = 96;
const peak = 40;
const half = 18;
const xs = [130, 250, 370, 490];

const spiky =
  `M60 ${base} ` +
  xs
    .map((x) => `L${x - half} ${base} L${x} ${peak} L${x + half} ${base}`)
    .join(' ') +
  ` L600 ${base}`;
const spikeArea = `${spiky} L600 ${base} L60 ${base} Z`;

const flat =
  'M60 168 C120 164, 180 172, 240 168 S360 164, 420 169 S540 172, 600 168';
const flatArea = `${flat} L600 ${base} L60 ${base} Z`;
---

<svg
  class="diagram st"
  viewBox="0 0 640 236"
  role="img"
  aria-label="One workload drawn two ways over the same timeline. With synchronized timers, every tab polls on the same tick, so the load stacks into tall spikes that cross the line marking what the backend can absorb. With jittered timers the identical total load spreads into a low flat band that stays under the line. The two shaded areas are the same size: same total requests, different shape."
>
  <!-- axes -->
  <line x1="60" y1={base} x2="600" y2={base} class="conn"></line>
  {
    xs.map((x, i) => (
      <g>
        <line class="conn" x1={x} y1={base} x2={x} y2={base + 5} />
        <text x={x} y={base + 18} text-anchor="middle" class="t-faint t-note">
          :{String(i * 10).padStart(2, '0')}
        </text>
      </g>
    ))
  }
  <text
    x="20"
    y="112"
    text-anchor="middle"
    class="t-faint t-note"
    transform="rotate(-90 20 112)">reads / sec</text
  >

  <!-- capacity -->
  <line x1="60" y1={cap} x2="600" y2={cap} class="st-cap"></line>
  <text x="598" y={cap - 6} text-anchor="end" class="t-faint t-note"
    >capacity</text
  >

  <!-- jittered: same load, flat -->
  <path class="st-area-ok" d={flatArea}></path>
  <path class="st-flat" d={flat}></path>
  <text x="598" y="160" text-anchor="end" class="t-ok t-label">jittered</text>

  <!-- synchronized: stacked into spikes -->
  <path class="st-area-fail" d={spikeArea}></path>
  <path class="st-spiky" d={spiky}></path>
  <text x="310" y="30" text-anchor="middle" class="t-fail t-label"
    >synchronized</text
  >

  <text x="330" y="226" text-anchor="middle" class="t-faint t-note"
    >identical total load — only the shape changes</text
  >
</svg>

<style>
  .st .st-cap {
    stroke: var(--faint);
    stroke-width: 1.5;
    stroke-dasharray: 5 6;
    fill: none;
  }
  .st .st-spiky {
    stroke: var(--fail);
    stroke-width: 2;
    fill: none;
    stroke-linejoin: round;
  }
  .st .st-flat {
    stroke: var(--accent);
    stroke-width: 2;
    fill: none;
  }
  .st .st-area-fail {
    fill: var(--fail);
    fill-opacity: 0.14;
  }
  .st .st-area-ok {
    fill: var(--accent);
    fill-opacity: 0.16;
  }
  @media (prefers-reduced-motion: no-preference) {
    .st .st-spiky {
      stroke-dasharray: 1800;
      stroke-dashoffset: 1800;
      animation: st-draw 1.1s ease-out forwards;
    }
    .st .st-flat {
      stroke-dasharray: 700;
      stroke-dashoffset: 700;
      animation: st-draw 0.9s ease-out 0.5s forwards;
    }
    .st .st-area-fail {
      opacity: 0;
      animation: st-fade 0.6s ease-out 0.9s forwards;
    }
    .st .st-area-ok {
      opacity: 0;
      animation: st-fade 0.6s ease-out 0.4s forwards;
    }
  }
  @keyframes st-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes st-fade {
    to {
      opacity: 1;
    }
  }
</style>
