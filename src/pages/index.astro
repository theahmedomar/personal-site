---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { site } from '../lib/site';
import { readingTime } from '../lib/reading-time';
import ahmedPhoto from '../assets/ahmed.jpg';

const sameAs = [site.github, site.linkedin].filter((url) => url && url !== '#');
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  url: site.url,
  jobTitle: 'Software Engineer',
  email: site.email,
  sameAs,
};

const posts = (
  await getCollection('articles', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  )
)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const fmt = (d) =>
  new Date(d).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
---

<Base current="/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  </Fragment>

  <div class="top anim">
    <Image
      class="avatar"
      src={ahmedPhoto}
      alt={site.name}
      width={224}
      height={224}
      loading="eager"
      fetchpriority="high"
    />
    <div>
      <h1>{site.name}</h1>
      <div class="tag">Software Engineer</div>
    </div>
  </div>

  <div class="bio anim">
    <p>
      I'm a full-stack software engineer in Cairo. I enjoy building reliable &
      scalable systems.
    </p>
    <p>
      In a previous life I studied Electrical Engineering and worked in ML &
      Data Science.
    </p>
  </div>

  {
    posts.length > 0 && (
      <section class="posts anim">
        {posts.map((a) => (
          <article class="post">
            <h3 class="post-title">
              <a href={`/writing/${a.id}/`}>{a.data.title}</a>
            </h3>
            <p class="post-meta">
              {fmt(a.data.pubDate)} · {readingTime(a.body ?? '')}
            </p>
            <p class="post-desc">{a.data.description}</p>
          </article>
        ))}
      </section>
    )
  }
</Base>
