---
import Base from './Base.astro';
import ShareLinks from '../components/ShareLinks.astro';
import SignupForm from '../components/SignupForm.astro';
import { site } from '../lib/site';

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  readingTime,
  image,
  prev,
  next,
} = Astro.props;

const shareUrl = new URL(Astro.url.pathname, Astro.site).href;

const fmt = (d) =>
  new Date(d).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: new Date(pubDate).toISOString(),
  ...(updatedDate && { dateModified: new Date(updatedDate).toISOString() }),
  author: { '@type': 'Person', name: site.name, url: site.url },
};
---

<Base
  title={title}
  description={description}
  current="/writing"
  type="article"
  image={image}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
  </Fragment>

  <article class="anim">
    <header class="article-head">
      <h1 class="article-title">{title}</h1>
      <p class="article-dek">{description}</p>
      <div class="article-meta">
        <span>{fmt(pubDate)}</span>
        <span class="sep">·</span>
        <span>{readingTime}</span>
        {
          updatedDate && (
            <>
              <span class="sep">·</span>
              <span>updated {fmt(updatedDate)}</span>
            </>
          )
        }
      </div>
      {
        tags.length > 0 && (
          <ul class="tags">
            {tags.map((t) => (
              <li class="tag-chip">{t}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose">
      <slot />
    </div>

    <SignupForm />

    <ShareLinks url={shareUrl} title={title} />

    {
      (prev || next) && (
        <nav class="post-nav" aria-label="Adjacent posts">
          {prev && (
            <a href={prev.href} rel="prev" class="post-nav-link">
              <span class="post-nav-label">← Previous</span>
              <span class="post-nav-title">{prev.title}</span>
            </a>
          )}
          {next && (
            <a href={next.href} rel="next" class="post-nav-link next">
              <span class="post-nav-label">Next →</span>
              <span class="post-nav-title">{next.title}</span>
            </a>
          )}
        </nav>
      )
    }
  </article>
</Base>
